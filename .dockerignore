# Git files
.git
.gitignore
.gitattributes

# ── Knowledge content lives in volumes, never in the image ──────────
# (the content-fetch service downloads the sources.yaml manifest into
# the jic-sources volume; repo-committed PDFs are seeded via a bind
# mount at runtime)
public/sources/

# Data files (mounted as volumes)
data/
sources/
pdfs/
gguf_models/

# Python cache (no longer needed for C++ version)
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
venv/
ENV/

# Documentation
docs/
*.md
LICENSE
TODO.md
build-notes/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Tests
tests/
test.sh
*.test

# Helper scripts (host-side only), except the content fetcher which is
# baked into the image for the compose "fetch" profile
helper-scripts/
!helper-scripts/fetch-source-data.sh

# Build artifacts
build/
cmake-build-*/
*.o
*.a
*.so
*.dylib

# Build cache
.buildx-cache/
.cache/

# Environment files
.env
.env.*

# Logs
*.log

